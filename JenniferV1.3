-- load rayfield
local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer

local speedValue = 16
local speedEnabled = false
local executeStart = os.clock()

-- window
local Window = Rayfield:CreateWindow({
    Name = "JenniferW v1.3",
    LoadingTitle = "JenniferW v1.3",
    LoadingSubtitle = "by Shoya",
    ConfigurationSaving = {
        Enabled = false,
    },
})

-- tabs
local MainTab = Window:CreateTab("Main", 4483362458)
local SettingsTab = Window:CreateTab("Settings", 4483362458)
local InfoTab = Window:CreateTab("Info", 4483362458)

-- notification
Rayfield:Notify({
    Title = "JenniferW v1.3",
    Content = "Loaded!",
    Duration = 4,
})

-- MAIN TAB

MainTab:CreateSection("Player")

MainTab:CreateInput({
    Name = "WalkSpeed Value",
    PlaceholderText = "Example: 50",
    RemoveTextAfterFocusLost = false,
    Callback = function(text)
        local num = tonumber(text)
        if num then
            speedValue = num
        end
    end,
})

MainTab:CreateToggle({
    Name = "Enable WalkSpeed",
    CurrentValue = false,
    Flag = "WalkSpeedToggle",
    Callback = function(state)
        speedEnabled = state
    end,
})

-- enforce speed
task.spawn(function()
    while true do
        task.wait(0.1)
        if speedEnabled then
            local char = player.Character
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid.WalkSpeed = speedValue
            end
        end
    end
end)

-- SETTINGS TAB

SettingsTab:CreateButton({
    Name = "Unload Hub",
    Callback = function()
        Rayfield:Destroy()
    end,
})

-- INFO TAB
InfoTab:CreateSection("Player Info")

InfoTab:CreateParagraph({
    Title = "Username",
    Content = string.format("%s (@%s)", player.DisplayName, player.Name),
})

local avatarContent, avatarReady = Players:GetUserThumbnailAsync(
    player.UserId,
    Enum.ThumbnailType.HeadShot,
    Enum.ThumbnailSize.Size420x420
)

local avatarShown = false
local avatarLabelOk, avatarLabel = pcall(function()
    return InfoTab:CreateLabel("Roblox Avatar", avatarContent)
end)

if avatarLabelOk and avatarLabel then
    avatarShown = true
else
    local avatarPngUrl = string.format(
        "https://www.roblox.com/headshot-thumbnail/image?userId=%d&width=420&height=420&format=png",
        player.UserId
    )
    InfoTab:CreateParagraph({
        Title = "Roblox Avatar PNG",
        Content = avatarPngUrl,
    })
end

InfoTab:CreateParagraph({
    Title = "Avatar Status",
    Content = avatarShown and (avatarReady and "Loaded" or "Loading") or "Fallback URL mode",
})

local stopwatchParagraph = InfoTab:CreateParagraph({
    Title = "Executed For",
    Content = "00:00:00",
})

InfoTab:CreateParagraph({
    Title = "JenniferW v1.3",
    Content = "UI toggle key: 0",
})

local function formatElapsed(seconds)
    local total = math.floor(seconds)
    local hours = math.floor(total / 3600)
    local minutes = math.floor((total % 3600) / 60)
    local secs = total % 60
    return string.format("%02d:%02d:%02d", hours, minutes, secs)
end

task.spawn(function()
    while true do
        task.wait(1)
        stopwatchParagraph:Set({
            Title = "Executed For",
            Content = formatElapsed(os.clock() - executeStart),
        })
    end
end)

-- UI TOGGLE

UIS.InputBegan:Connect(function(input, gp)
    if gp then
        return
    end
    if input.KeyCode == Enum.KeyCode.Zero then
        Rayfield:Toggle()
    end
end)
