local function findLuckyArrowInstance()
    local containers = {
        player:FindFirstChild("Backpack"),
        player.Character,
        player:FindFirstChild("PlayerGui"),
        player:FindFirstChild("Data"),
        player:FindFirstChild("Inventory"),
    }

    local function nameMatch(n)
        return string.lower((n or "")):gsub("%s+", "") == "luckyarrow"
    end

    for _, container in ipairs(containers) do
        if container then
            for _, obj in ipairs(container:GetDescendants()) do
                if nameMatch(obj.Name) then
                    return obj
                end
            end
        end
    end

    return nil
end

local function findAmountHolder(item)
    for _, child in ipairs(item:GetDescendants()) do
        if (child:IsA("IntValue") or child:IsA("NumberValue")) and amountFieldNames[child.Name] then
            return "value", child
        end
    end

    for _, child in ipairs(item:GetDescendants()) do
        if child:IsA("IntValue") or child:IsA("NumberValue") then
            return "value", child
        end
    end

    for name, _ in pairs(amountFieldNames) do
        local attr = item:GetAttribute(name)
        if typeof(attr) == "number" then
            return "attribute", name
        end
    end

    return nil, nil
end

local function setLuckyArrowAmountToTen()
    local item = findLuckyArrowInstance()
    if not item then
        print("Lucky Arrow not found in Backpack/Character/PlayerGui/Data/Inventory")
        return
    end

    print("Lucky Arrow path:", item:GetFullName(), "| Class:", item.ClassName)

    local holderType, holder = findAmountHolder(item)
    if holderType == "value" and holder then
        print("Current amount:", holder.Value)
        holder.Value = 10
        print("New amount:", holder.Value)
        return
    end

    if holderType == "attribute" and holder then
        local current = item:GetAttribute(holder)
        print("Current amount:", current)
        item:SetAttribute(holder, 10)
        print("New amount:", item:GetAttribute(holder))
        return
    end

    print("Item found but no amount value detected")
end

local function isValueObject(obj)
    return obj:IsA("IntValue") or obj:IsA("NumberValue") or obj:IsA("StringValue") or obj:IsA("BoolValue")
end

local function printAttrs(obj)
    for k, v in pairs(obj:GetAttributes()) do
        print(("  [Attr] %s = %s"):format(k, tostring(v)))
    end
end

local function dumpNearby(obj)
    print("MATCH:", obj:GetFullName(), "|", obj.ClassName)
    if isValueObject(obj) then
        print("  [Value]", obj.Name, "=", tostring(obj.Value))
    end
    printAttrs(obj)

    local parent = obj.Parent
    if parent then
        print("  -- Parent children --")
        for _, c in ipairs(parent:GetChildren()) do
            if isValueObject(c) then
                print(("    %s (%s) = %s"):format(c.Name, c.ClassName, tostring(c.Value)))
            else
                local attrs = c:GetAttributes()
                if next(attrs) ~= nil then
                    print(("    %s (%s) has attributes"):format(c.Name, c.ClassName))
                    for ak, av in pairs(attrs) do
                        print(("      %s = %s"):format(ak, tostring(av)))
                    end
                end
            end
        end
    end
end

local function debugLuckyArrowScrape()
    local roots = {
        player,
        player:FindFirstChild("PlayerGui"),
        player:FindFirstChild("Backpack"),
        player.Character,
    }

    local seen = {}
    local totalMatches = 0

    for _, root in ipairs(roots) do
        if root then
            for _, obj in ipairs(root:GetDescendants()) do
                local n = string.lower(obj.Name)
                if n:find("lucky") or n:find("arrow") or n:find("item") or n:find("inventory") then
                    if not seen[obj] then
                        seen[obj] = true
                        totalMatches += 1
                        dumpNearby(obj)
                    end
                end
            end
        end
    end

    print("Lucky Arrow debug scan complete. Matches:", totalMatches)
end

local function ensureFlyForces(humanoid, hrp)
    if humanoid then
        humanoid.PlatformStand = true
        humanoid.AutoRotate = false
        humanoid:ChangeState(Enum.HumanoidStateType.Physics)
    end

    if not flyGyro or flyGyro.Parent ~= hrp then
        if flyGyro then
            flyGyro:Destroy()
        end
        flyGyro = Instance.new("BodyGyro")
        flyGyro.P = 9e4
        flyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        flyGyro.CFrame = hrp.CFrame
        flyGyro.Parent = hrp
    end

    if not flyVelocity or flyVelocity.Parent ~= hrp then
        if flyVelocity then
            flyVelocity:Destroy()
        end
        flyVelocity = Instance.new("BodyVelocity")
        flyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        flyVelocity.Velocity = Vector3.zero
        flyVelocity.Parent = hrp
    end
end

local function stopFly()
    local char = player.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if humanoid then
        humanoid.PlatformStand = false
        humanoid.AutoRotate = true
        humanoid.Sit = false
        humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        task.defer(function()
            if humanoid and humanoid.Parent then
                humanoid:ChangeState(Enum.HumanoidStateType.Running)
            end
        end)
    end
    if hrp then
        hrp.AssemblyAngularVelocity = Vector3.zero
    end
    if flyConnection then
        flyConnection:Disconnect()
        flyConnection = nil
    end
    if flyVelocity then
        flyVelocity:Destroy()
        flyVelocity = nil
    end
    if flyGyro then
        flyGyro:Destroy()
        flyGyro = nil
    end
    flyKeys.W = false
    flyKeys.A = false
    flyKeys.S = false
    flyKeys.D = false
    flyKeys.Space = false
    flyKeys.Ctrl = false
end

local function startFly()
    if flyConnection then
        return
    end

    local char = player.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not humanoid or not hrp then
        return
    end

    ensureFlyForces(humanoid, hrp)

    flyConnection = RunService.RenderStepped:Connect(function()
        if not flyEnabled then
            return
        end

        local currentChar = player.Character
        local currentHumanoid = currentChar and currentChar:FindFirstChildOfClass("Humanoid")
        local currentHrp = currentChar and currentChar:FindFirstChild("HumanoidRootPart")
        if not currentHumanoid or not currentHrp then
            stopFly()
            return
        end

        local cam = workspace.CurrentCamera
        if not cam then
            return
        end

        ensureFlyForces(currentHumanoid, currentHrp)

        local moveVector = Vector3.zero
        if flyKeys.W then
            moveVector += cam.CFrame.LookVector
        end
        if flyKeys.S then
            moveVector -= cam.CFrame.LookVector
        end
        if flyKeys.D then
            moveVector += cam.CFrame.RightVector
        end
        if flyKeys.A then
            moveVector -= cam.CFrame.RightVector
        end
        if flyKeys.Space then
            moveVector += Vector3.new(0, 1, 0)
        end
        if flyKeys.Ctrl then
            moveVector -= Vector3.new(0, 1, 0)
        end

        if moveVector.Magnitude > 0 then
            flyVelocity.Velocity = moveVector.Unit * flyValue
        else
            flyVelocity.Velocity = Vector3.zero
        end
        flyGyro.CFrame = cam.CFrame
    end)
end

