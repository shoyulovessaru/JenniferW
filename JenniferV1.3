-- draggable avatar panel
local dragging = false
local dragInput
local dragStart
local startPos

local function updateDrag(input)
    local delta = input.Position - dragStart
    avatarFrame.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
end

avatarFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = avatarFrame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

avatarFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input == dragInput then
        updateDrag(input)
    end
end)

task.spawn(function()
    local Stats = game:GetService("Stats")
    local dataPingItem = nil
    pcall(function()
        dataPingItem = Stats.Network.ServerStatsItem["Data Ping"]
    end)

    while true do
        task.wait(1)
        local elapsed = formatElapsed(os.clock() - executeStart)
        stopwatchParagraph:Set({
            Title = "Executed For",
            Content = elapsed,
        })
        if avatarTimer and avatarTimer.Parent then
            avatarTimer.Text = "Executed: " .. elapsed
        end
        if avatarPing and avatarPing.Parent then
            local pingText = "Ping: N/A"
            if dataPingItem then
                local ok, value = pcall(function()
                    return dataPingItem:GetValueString()
                end)
                if ok and value then
                    pingText = "Ping: " .. value
                end
            end
            avatarPing.Text = pingText
        end
    end
end)

-- UI TOGGLE

UIS.InputBegan:Connect(function(input, gp)
    if gp then
        return
    end
    if input.KeyCode == Enum.KeyCode.Zero then
        Rayfield:Toggle()
        isUiVisible = not isUiVisible
        if avatarFrame then
            avatarFrame.Visible = isUiVisible
        end
    end
end)
